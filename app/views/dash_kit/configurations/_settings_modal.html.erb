<div id="dashboard-settings-modal">
  <dialog class="modal p-0 rounded-lg shadow-xl bg-white dark:bg-zinc-900 backdrop:bg-gray-500/50 max-w-md w-full" data-modal-target="dialog" data-action="click->modal#backdropClick close->modal#handleClose">
    <div class="p-6" data-controller="sortable-list" data-sortable-list-reorder-url-value="<%= dash_kit.reorder_configuration_path(config) %>">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Dashboard Settings</h3>
        <button type="button" class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300" data-action="sortable-list#done modal#close">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Show, hide, or reorder dashboard widgets.</p>

      <div class="space-y-2" data-sortable-list-target="list">
        <% config.widget_order.each do |widget_key| %>
          <% widget_def = config.available_widgets[widget_key.to_sym] %>
          <% next unless widget_def %>
          <div data-widget-key="<%= widget_key %>" class="flex items-center justify-between p-3 rounded-lg border border-gray-200 dark:border-zinc-700 <%= config.widget_visible?(widget_key) ? 'bg-white dark:bg-zinc-800' : 'bg-gray-50 dark:bg-zinc-900 opacity-60' %>">
            <div class="flex items-center gap-3">
              <%= form_with url: dash_kit.toggle_widget_configuration_path(config), method: :post, data: {turbo_frame: "_top"} do |f| %>
                <%= hidden_field_tag :widget_key, widget_key %>
                <button type="submit" class="flex items-center justify-center w-5 h-5 rounded border <%= config.widget_visible?(widget_key) ? 'bg-accent-600 border-accent-600' : 'border-gray-300 dark:border-zinc-600' %>" data-action="sortable-list#markDirty">
                  <% if config.widget_visible?(widget_key) %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-3 text-white">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  <% end %>
                </button>
              <% end %>
              <span class="text-sm font-medium text-gray-900 dark:text-white"><%= widget_def[:label] %></span>
            </div>

            <div data-sortable-handle class="cursor-grab active:cursor-grabbing p-1.5 rounded hover:bg-gray-100 dark:hover:bg-zinc-700 text-gray-400 dark:text-gray-500 touch-none">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="size-5">
                <circle cx="9" cy="5" r="1.5" />
                <circle cx="15" cy="5" r="1.5" />
                <circle cx="9" cy="12" r="1.5" />
                <circle cx="15" cy="12" r="1.5" />
                <circle cx="9" cy="19" r="1.5" />
                <circle cx="15" cy="19" r="1.5" />
              </svg>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-6 flex justify-end">
        <button type="button" class="rounded-md bg-accent-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-accent-500" data-action="sortable-list#done modal#close">
          Done
        </button>
      </div>
    </div>
  </dialog>
</div>
